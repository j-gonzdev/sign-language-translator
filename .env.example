# Entorno 
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# Base de datos 
# Desarrollo local (docker-compose PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asl_db

# Producción (Supabase) — rellenar solo en Railway
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# JWT 
JWT_SECRET_KEY=cambia_esto_por_un_secreto_real_de_64_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase Storage 
# Solo necesario en producción
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=asl-files

# CORS 
# En desarrollo: http://localhost:4200 (Angular dev server)
# En producción: tu dominio de Vercel
ALLOWED_ORIGINS=http://localhost:4200

# Rate limiting 
RATE_LIMIT_PER_MINUTE=60

# ML Service 
ML_SERVICE_URL=http://localhost:8001